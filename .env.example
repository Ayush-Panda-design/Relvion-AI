# PostgreSQL connection string (with pgvector)
# Local: postgresql://user:password@localhost:5432/relvion
# Render (from Vercel): use External URL — app auto-enables SSL for remote hosts
DATABASE_URL=postgresql://user:password@localhost:5432/relvion

# Corsair Key Encryption Key — generate with: openssl rand -base64 32
CORSAIR_KEK=your-kek-here

# Gemini API Key — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Multiple Gemini keys for key rotation (optional, comma-separated)
# GEMINI_API_KEYS=key1,key2,key3

# Your app URL (used for OAuth callbacks in production)
APP_URL=http://localhost:3000

# Public URL for webhooks (use ngrok in dev — Google cannot reach localhost)
# WEBHOOK_BASE_URL=https://your-subdomain.ngrok-free.app

# Gmail Pub/Sub topic for push notifications (Google Cloud Console)
# GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push

# Calendar webhook verification token (optional)
# CALENDAR_WEBHOOK_TOKEN=relvion-calendar-token

# Secret for GET /api/migrate and `pnpm migrate` safety checks (optional in dev)
# MIGRATE_SECRET=your-random-secret

# Secret for cron endpoints (snooze release, etc.)
# CRON_SECRET=your-cron-secret

# Node environment
NODE_ENV=development
